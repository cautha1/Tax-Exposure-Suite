# Copy this file to .env and fill in your values
# Frontend uses ONLY the anon/public key — NEVER put service_role here

# Backend API base URL (proxied through Vite in dev)
VITE_API_BASE_URL=/api

# Supabase public project URL (safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase ANON/PUBLIC key only (NOT service_role)
# Find it in: Supabase dashboard → Settings → API → anon/public
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

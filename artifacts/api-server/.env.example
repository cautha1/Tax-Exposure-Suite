# TaxIntel API Server — copy to .env and fill in your values
# SECURITY: This file is safe to commit. Never commit .env (it has real secrets)

# Supabase project URL (find in Supabase dashboard → Settings → API → Project URL)
TAXINTEL_DB_URL=https://your-project-ref.supabase.co

# Supabase service_role key — BACKEND ONLY, never put this in frontend code
# Find in: Supabase dashboard → Settings → API → Project API keys → service_role
TAXINTEL_DB_KEY=eyJ...your-service-role-key...

NODE_ENV=development
PORT=8080
